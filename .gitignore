# Dependencies
node_modules/
**/node_modules/

# Build output
client/dist/
functions/*/dist/

# Catalyst secrets — must NEVER be committed (env vars, ZAID, etc).
# Keep catalyst-config.example.json in git with placeholder values instead.
functions/*/catalyst-config.json

# Student PII — names, mobile numbers, parent names. Never commit.
veena-students-import.json
*-import.json

# Claude Code per-user settings (local, not portable)
.claude/settings.local.json
.claude/launch.json

# SQLite database
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm

# Environment
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
