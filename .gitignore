# Dependencies
node_modules/
**/node_modules/

# Build output
client/dist/
functions/*/dist/

# Generated at deploy time by deploy.sh (git SHA stamp for /api/health)
functions/api/version.json

# Catalyst secrets — must NEVER be committed (env vars, ZAID, etc).
# Keep catalyst-config.example.json in git with placeholder values instead.
functions/*/catalyst-config.json

# Supabase secrets — service_role key + DB connection string. NEVER commit.
# Keep supabase-config.example.json in git with placeholder values instead.
functions/*/supabase-config.json

# Student PII — names, mobile numbers, parent names. Never commit.
veena-students-import.json
*-import.json

# Claude Code per-user settings (local, not portable)
.claude/settings.local.json
.claude/launch.json

# SQLite database
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm
server/data/.realbackup/

# Environment
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Synced from Platform Admin Plans editor at deploy time (scripts/sync-pricing.js)
pricing.overrides.json


# Catalyst CLI local project association (per-machine, never commit)
.catalystrc
catalyst.json.live.bak

# Never commit config backups (may contain secrets)
*.bak
